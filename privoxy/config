# IPv4-only listener (IPv6 disabled)
listen-address  127.0.0.1:8118

toggle  1
enable-remote-toggle  0
enable-remote-http-toggle  0
enable-edit-actions 0
enforce-blocks 0

# Erhöhte Timeouts für langsame Tor-Circuits
socket-timeout 300

# Tor-Integration für anonyme Exit-IP
# Alle Requests werden über Tor SOCKS5 geleitet (localhost, nicht Docker-Service)
# socks5t = transparent DNS (verhindert DNS-Leaks)
forward-socks5t /        127.0.0.1:9050 .

# Lokale Netzwerk-Bypasses (verhindert Tor für interne IPs)
forward 192.168.*.*/     .
forward 127.*.*.*/       .
forward localhost/       .

# Kein Forward auf Squid setzen, sonst entsteht eine Proxy-Schleife.
# Privoxy leitet über Tor weiter für anonyme Egress-IP.

logdir /var/log/privoxy
